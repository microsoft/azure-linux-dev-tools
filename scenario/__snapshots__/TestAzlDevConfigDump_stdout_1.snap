[project]
description = 'simple'
log-dir = '/workdir/build/logs'
work-dir = '/workdir/build/work'
output-dir = '/workdir/out'
rendered-specs-dir = '/workdir/SPECS'
lock-dir = '/workdir/locks'

[component-groups]
[component-groups.default]
specs = ['/workdir/**/*.spec']
excluded-paths = ['/workdir/build/**', '/workdir/out/**']

